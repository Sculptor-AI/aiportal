{
  "name": "aiportal-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "npm run build --prefix ../frontend && shx rm -rf dist && shx cp -r ../frontend/dist ./dist",
    "build:worker": "esbuild worker.js --bundle --format=esm --outfile=dist/_worker.js --conditions=workerd --banner:js=\"// Cloudflare Pages Worker\" --external:node:*",
    "build:pages": "npm run build && npm run build:worker"
  },
  "dependencies": {
    "hono": "^4.11.10"
  },
  "devDependencies": {
    "esbuild": "^0.25.12",
    "shx": "^0.4.0",
    "wrangler": "^4.59.1"
  }
}
